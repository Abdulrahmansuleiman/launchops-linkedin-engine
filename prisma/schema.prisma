generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONNECTED
  DM_SENT
  RESPONDED
  MEETING_BOOKED
  DEMO_SENT
  CLIENT_WON
  CLIENT_LOST
  ARCHIVED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum ContentStage {
  IDEAS
  SCRIPTING
  EDITING
  QA
  POSTED
}

enum FeedbackRating {
  GREAT
  GOOD
  AVERAGE
  FLOOPED
}

model Account {
  id              String   @id @default(cuid())
  name            String?
  email           String   @unique
  password        String?
  image           String?
  telegramChatId  String?
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads    Lead[]
  clients  Client[]
  posts    Post[]
  ideas    ContentIdea[]
  sequences OutreachSequence[]
  competitorPosts CompetitorPost[]
  weeklyReports WeeklyReport[]
  ads Ad[]
}

model Lead {
  id        String   @id @default(cuid())
  accountId String
  linkedinUrl String?
  name      String?
  headline  String?
  company   String?
  location  String?
  industry  String?
  profilePicture String?
  followerCount Int?
  mutualConnections Int?
  email     String?
  phone     String?
  score     Int      @default(0)
  scoreReason String?
  scoreComponents Json?
  enrichmentData Json?
  notes     String?
  status    LeadStatus @default(NEW)
  connectedAt DateTime?
  lastContactedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  activities LeadActivity[]
  pipelineEntries PipelineEntry[]
  outreachMessages OutreachMessage[]
  client Client?

  @@index([accountId])
  @@index([status])
  @@index([score])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  content   String?
  metadata  Json?
  timestamp DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model PipelineEntry {
  id        String   @id @default(cuid())
  leadId    String
  stage     String
  value     Float?
  probability Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([stage])
}

model Post {
  id        String   @id @default(cuid())
  accountId String
  content   String
  topic     String?
  tone      String?
  stage     ContentStage @default(IDEAS)
  status    PostStatus @default(DRAFT)
  score     Int?
  scoreReason String?
  impressionPrediction String?
  scoreAnalysis String?
  headlines Json?
  scheduledFor DateTime?
  publishedAt DateTime?
  linkedinUrl String?
  aiGenerated Boolean @default(false)
  feedbackRating FeedbackRating?
  feedbackNotes String?
  impressions Int?
  reach     Int?
  likes     Int?
  comments  Int?
  shares    Int?
  saves     Int?
  weekLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
  @@index([weekLabel])
}

model ContentIdea {
  id        String   @id @default(cuid())
  accountId String
  topic     String
  angle     String?
  source    String?
  sourceUrl String?
  score     Int?
  aiGenerated Boolean @default(true)
  status    String @default("saved")
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

model OutreachSequence {
  id        String   @id @default(cuid())
  accountId String
  name      String
  steps     Json
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  messages OutreachMessage[]

  @@index([accountId])
}

model OutreachMessage {
  id         String   @id @default(cuid())
  sequenceId String
  leadId     String?
  stepNumber Int
  content    String
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  status     String @default("draft")
  createdAt  DateTime @default(now())

  sequence OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead     Lead?             @relation(fields: [leadId], references: [id])

  @@index([sequenceId])
  @@index([leadId])
}

model CompetitorPost {
  id        String   @id @default(cuid())
  accountId String
  authorName String
  authorUrl String?
  content   String
  topic     String?
  engagement Json?
  analysis  Json?
  scrapedAt DateTime @default(now())
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

enum OnboardingStatus {
  PENDING_FORM
  FORM_SENT
  FORM_COMPLETED
  CONTRACT_DRAFTED
  CONTRACT_SIGNED
  ONBOARDED
}

model Client {
  id        String   @id @default(cuid())
  accountId String
  leadId    String   @unique
  companyName String
  contactName  String
  contactEmail String?
  contactPhone String?
  website   String?
  industry  String?
  profilePicture String?

  services  String[]
  scope     String?
  goals     String?

  monthlyRetainer   Float?
  setupFee          Float?
  contractDuration  Int?
  paymentTerms      String?

  onboardingStatus OnboardingStatus @default(PENDING_FORM)
  pipelineStage    String @default("Active")
  contractContent  String?
  contractGeneratedAt DateTime?
  signedAt         DateTime?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account   @relation(fields: [accountId], references: [id])
  lead     Lead      @relation(fields: [leadId], references: [id])
  projects Project[]

  @@index([accountId])
  @@index([onboardingStatus])
  @@index([pipelineStage])
}

model Project {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      String   @default("active")
  startDate   DateTime?
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([clientId])
  @@index([status])
}

model Task {
  id            String    @id @default(cuid())
  projectId     String?
  title         String
  description   String?
  status        String    @default("todo")
  priority      String    @default("medium")
  scope         String    @default("client")
  pipelineStage String?
  assignee      String?
  deadline      DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([scope])
  @@index([pipelineStage])
  @@index([status])
  @@index([deadline])
}

enum AdStage {
  WRITING
  SELECTION
  REVIEW
  PUBLISHED
}

model Ad {
  id        String   @id @default(cuid())
  accountId String
  content   String
  hook      String?
  body      String?
  cta       String?
  angle     String?
  score     Int?
  scoreReason String?
  impressionPrediction String?
  stage     AdStage  @default(WRITING)
  topic     String?
  platform  String?
  tags      String[]
  service   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  publishedAt DateTime?

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([stage])
}

model WeeklyReport {
  id        String   @id @default(cuid())
  accountId String
  weekLabel String
  report    Json
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([weekLabel])
}
